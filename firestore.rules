rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    // High-level role checks
    
    // Superadmin: Can do everything (Delete, Deactivate, etc.)
    function isSuperAdmin() {
      return request.auth.token.role == 'superadmin';
    }

    // Admin: Can edit modules, translations, improvements. (Includes Superadmin)
    function isAdmin() {
      return request.auth.token.role == 'admin' || isSuperAdmin();
    }

    // Granular Permissions check
    function hasPermission(perm) {
      // We check if the token has a permissions array and the required perm is in it.
      // In Firestore rules, we can check if a list has a value using `in`.
      let perms = request.auth.token.permissions;
      return perms != null && perm in perms;
    }

    // Team Office: Can edit text of records/registrations. (Includes Admin and Superadmin)
    function isTeamOffice() {
      return request.auth.token.role == 'team_office' || isAdmin();
    }

    // General Access: Anyone with admin: true claim (view access) or specific access_admin_panel permission
    function hasDashboardAccess() {
      return request.auth.token.admin == true || hasPermission('access_admin_panel'); 
    }

    // Registrations collection
    match /registrations/{registrationId} {
      allow create: if true; // Public registration
      
      // Read: Owner or anyone with dashboard access (Superadmin, Admin, Team Office)
      allow read: if isAuthenticated() && (resource.data.ownerUid == request.auth.uid || hasDashboardAccess());
      
      // Update: Owner or Team Office (text editing)
      allow update: if isAuthenticated() && (resource.data.ownerUid == request.auth.uid || isTeamOffice());
      
      // Delete: Superadmin only
      allow delete: if isSuperAdmin();
    }

    // Clients collection (public directory)
    match /clients/{clientId} {
      allow read: if true; // Public
      
      allow create: if isAuthenticated(); // Or restricted to admins? Keeping existing logic
      
      // Update: Owner or Team Office
      allow update: if isAuthenticated() && (resource.data.ownerUid == request.auth.uid || isTeamOffice());
      
      // Delete: Superadmin only
      allow delete: if isSuperAdmin();
    }

    // Businesses collection
    match /businesses/{businessId} {
      allow read: if true;
      
      // Create/Update: Team Office (Data entry/Edit)
      allow create, update: if isTeamOffice();
      
      // Delete: Superadmin only
      allow delete: if isSuperAdmin();
    }
    
    // Admins collection
    match /admins/{adminId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only manual or cloud function writes
    }

    // Pricing Plans (Config - Admin/Superadmin)
    match /pricing_plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Private Profiles
    match /private_profiles/{userId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || hasDashboardAccess());
    }
    
    // Ad Banners (Config - Admin/Superadmin)
    match /ads_banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('access_ads_manager');
    }
    
    // Ad Events (Admin/API write only, Admin read)
    match /ad_events/{eventId} {
      allow read: if hasDashboardAccess();
      allow write: if false;
    }

    // Recommendations (moved to nested under /clients)

    // AI Knowledge Base (Config - Admin/Superadmin)
    match /ai_knowledge_snippets/{snippetId} {
      allow read, write: if isAdmin();
    }
    match /ai_knowledge_files/{fileId} {
      allow read, write: if isAdmin();
    } // Removed debug true

    // Tickets collection
    match /tickets/{ticketId} {
      allow create: if isAuthenticated();
      allow read, update: if isAuthenticated() && (resource.data.uid == request.auth.uid || isTeamOffice());
      allow delete: if isSuperAdmin(); // Only Superadmin deletes
    }

    // Analytics Events (for Admin Dashboard)
    match /analyticsEvents/{eventId} {
      allow read: if hasDashboardAccess();
      allow write: if false;
    }

    // Site Visits (for Admin Dashboard)
    match /site_visits/{visitId} {
      allow read: if hasDashboardAccess();
      allow write: if false; // Written securely via Server Admin SDK
    }

    // Daily Ad Stats (for Admin Dashboard)
    match /ad_stats_daily/{statId} {
      allow read: if hasDashboardAccess();
      allow write: if false;
    }

    // Feedbacks collection
    match /feedbacks/{feedbackId} {
      allow create: if isAuthenticated();
      allow read: if resource.data.status == 'approved' || isAdmin();
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    // Categories collection (Config - Admin/Superadmin)
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin() || hasPermission('manage_products'); 
    }

    // General Information (Admin Dashboard Calendar & Notes)
    match /system_modules/{moduleId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    match /general_info/{infoId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isAuthenticated();
        allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      }
    }

    // Community Wall
    match /community_posts/{postId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());

      match /comments/{commentId} {
        allow read: if true;
        // Allow create if auth and basic validation? Just auth for now.
        allow create: if isAuthenticated();
        // Allow update/delete if owner or admin
        allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      }
    }

    // Counters collection for IDs
    match /counters/{counterId} {
      allow read, write: if hasDashboardAccess(); // Needed for generating IDs (Team Office needs this)
    }

    // Recommendations (Collection Group)
    match /{path=**}/recommendations/{recommendationId} {
      allow create: if true;
      allow read: if resource.data.status == 'approved' || isAdmin() || isTeamOffice() || resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || isTeamOffice() || resource.data.userId == request.auth.uid;
      allow delete: if isSuperAdmin();
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow read, update: if isAuthenticated() && resource.data.toUserId == request.auth.uid;
      allow create: if isAuthenticated();
    }

    // TrustBoard Posts
    match /trustboard_posts/{postId} {
      allow read: if true; // Public can see the feed
      allow write: if isAdmin(); // Created through secure Server Actions
    }

    // Friend Requests collection
    match /friend_requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.fromUserId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.toUserId == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.fromUserId == request.auth.uid || resource.data.toUserId == request.auth.uid);
    }

    // User Payout Methods
    match /user_payout_methods/{userId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || hasDashboardAccess());
    }

    // Locations ecosystem (Read by client SDK in dashboards)
    match /system_locations/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /neighborhoods/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /location_suggestions/{docId} {
      allow read, write: if isAdmin();
      allow create: if isAuthenticated();
    }

    // Apoyo Social Requests
    match /apoyo_social_requests/{requestId} {
      allow create: if true; // Formularios públicos con token
      allow read, update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    // Apoyo Social Invites
    match /apoyo_social_invites/{inviteId} {
      allow read: if isAdmin();
      allow write: if false; // Solo acciones del servidor pueden crear
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
